# ================================================
#  KTP HTTP SERVER - Environment Configuration
# ================================================
#  Salin file ini menjadi .env lalu sesuaikan.
#  Jangan commit file .env ke Git!
# ================================================

# ── Server ──────────────────────────────────────
KTP_HOST       = 0.0.0.0
KTP_PORT       = 8080
KTP_SERVER_IP  = 192.168.1.1

# ── File & Folder ────────────────────────────────
KTP_LOG_FILE   = ktp_data.json
KTP_LOG_HTTP   = server.log
KTP_FOTO_DIR   = foto_ktp
